# ==============================
# GPS Relay Server — Environment
# ==============================

PORT=3001

# Redis (Memurai on Windows uses same default port)
REDIS_URL=redis://127.0.0.1:6379

# PostgreSQL (optional — only needed for history logging)
DATABASE_URL=postgresql://user:password@localhost:5432/routeroyal

# JWT Secret (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_key

# dev | production
NODE_ENV=dev
